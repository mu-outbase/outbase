name: OUTBASE Core05.6 Calendar Navigation unpack

on:
  push:
    branches:
      - main
    paths:
      - 'OUTBASE_MVPB_Core05_6_CalendarNav.zip'
      - '.github/workflows/unpack-core05-6.yml'
  workflow_dispatch:

permissions:
  contents: write

jobs:
  unpack:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Unzip Core05.6 package
        run: |
          set -e
          rm -rf /tmp/outbase_core05_6
          mkdir -p /tmp/outbase_core05_6
          unzip -o OUTBASE_MVPB_Core05_6_CalendarNav.zip -d /tmp/outbase_core05_6
          cp -R /tmp/outbase_core05_6/OUTBASE_MVPB_CORE05_6_CALENDAR_NAV/. ./
          rm -f OUTBASE_MVPB_Core05_6_CalendarNav.zip

      - name: Commit unpacked files
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add .
          if git diff --cached --quiet; then
            echo "No changes to commit"
          else
            git commit -m "Apply OUTBASE Core05.6 calendar navigation"
            git push
          fi
